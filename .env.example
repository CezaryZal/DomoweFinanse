# Public Supabase configuration (add values only in a local .env.local file)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional only for isolated local Gemini-worker experiments.
# Gemini used by the application reads its key from Supabase Edge Function secrets instead.
# Do not prefix this key with VITE_ and never commit its real value.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
